{
  "manifest_version": 3,
  "name": "快捷文本",
  "version": "1.0.0",
  "description": "快捷文本管理工具 - 快速复制常用文本，支持添加、编辑、删除、排序和导入导出",
  "action": {
    "default_popup": "popup.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Q"
      },
      "description": "打开快捷文本扩展"
    }
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}